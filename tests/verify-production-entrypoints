#!/usr/bin/env bash
set -euo pipefail

entrypoint="deploy/prd/portmason/pm-process-site-partials"

if [[ ! -r "$entrypoint" ]]; then
  echo "Missing staged Portmason entrypoint: $entrypoint" >&2
  echo "Run pm-setup from deploy/prd, then commit the staged share." >&2
  exit 1
fi

grep -Fq 'PORTMASON_SHARE: ${CONTAINER_ROOT}/portmason' deploy/prd/docker-compose.yml || {
  echo "Production Compose is not using the staged Portmason share." >&2
  exit 1
}

grep -Fq '$PORTMASON_SHARE/pm-process-site-partials' .github/workflows/gen-site-html.yml || {
  echo "The Pages workflow is not using the staged Portmason entrypoint." >&2
  exit 1
}

printf 'Staged Portmason entrypoint is ready.\n'
