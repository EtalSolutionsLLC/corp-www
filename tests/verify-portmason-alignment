#!/usr/bin/env bash
set -euo pipefail

required=(
  docker-compose.yml
  deploy/prd/docker-compose.yml
  deploy/prd/portmason/pm-setup
  deploy/prd/portmason/pm-process-site-partials
  www/collections/_system/render-collection
)

for path in "${required[@]}"; do
  [[ -e "$path" ]] || {
    echo "Missing required path: $path" >&2
    exit 1
  }
done

printf 'Basic Portmason site alignment is present.\n'
