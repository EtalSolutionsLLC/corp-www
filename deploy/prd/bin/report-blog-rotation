#!/usr/bin/env bash
set -euo pipefail

TARGET_REPO_PATH="${TARGET_REPO_PATH:-deploy/prd/www/index.html}"
TARGET_WORK_PATH="${TARGET_WORK_PATH:-www/index.html}"
EXPECTED_ROTATION_COUNT="${EXPECTED_ROTATION_COUNT:-3}"

old_html="$(mktemp)"
trap 'rm -f "$old_html"' EXIT

if ! git show "HEAD:${TARGET_REPO_PATH}" > "$old_html" 2>/dev/null; then
  echo "BLOG_ROTATION skipped reason=no_prior_file path=${TARGET_REPO_PATH}"
  exit 0
fi

if [ ! -f "$TARGET_WORK_PATH" ]; then
  echo "BLOG_ROTATION skipped reason=no_generated_file path=${TARGET_WORK_PATH}"
  exit 0
fi

python3 - "$old_html" "$TARGET_WORK_PATH" "$EXPECTED_ROTATION_COUNT" <<'PY'
import html
import re
import sys

old_path, new_path, expected_count = sys.argv[1], sys.argv[2], int(sys.argv[3])

def strip_tags(value):
    value = re.sub(r"<[^>]+>", "", value or "")
    value = html.unescape(value)
    return " ".join(value.split())

def extract_thread_block(text):
    match = re.search(
        r"<!--\s*PM:TRANSFORMATION-THREAD\s*-->(.*?)<!--\s*/PM:TRANSFORMATION-THREAD\s*-->",
        text,
        re.I | re.S,
    )
    return match.group(1) if match else text

def extract_entries(path):
    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        text = f.read()

    block = extract_thread_block(text)

    article_pattern = re.compile(
        r"""<article\b(?P<attrs>[^>]*\bdata-thread-post-id=["'](?P<id>[^"']+)["'][^>]*)>(?P<body>.*?)</article>""",
        re.I | re.S,
    )

    entries = []

    for match in article_pattern.finditer(block):
        attrs = match.group("attrs")
        body = match.group("body")
        post_id = match.group("id").strip()

        slot_match = re.search(r"""data-thread-slot=["']([^"']+)["']""", attrs, re.I)
        category_match = re.search(r"""data-post-category=["']([^"']+)["']""", attrs, re.I)
        h3_match = re.search(r"<h3[^>]*>(.*?)</h3>", body, re.I | re.S)
        summary_match = re.search(r"<p[^>]*>(.*?)</p>", body, re.I | re.S)

        slot = slot_match.group(1).strip() if slot_match else ""
        category = html.unescape(category_match.group(1).strip()) if category_match else ""
        title = strip_tags(h3_match.group(1)) if h3_match else f"TT-{post_id}"
        summary = strip_tags(summary_match.group(1)) if summary_match else ""

        entries.append({
            "id": post_id,
            "tt_id": f"TT-{int(post_id):03d}" if post_id.isdigit() else post_id,
            "slot": slot,
            "category": category,
            "title": title,
            "summary": summary,
        })

    seen = set()
    deduped = []

    for entry in entries:
        if entry["id"] in seen:
            continue
        seen.add(entry["id"])
        deduped.append(entry)

    return deduped

def print_entry(prefix, entry):
    title = html.escape(entry["title"], quote=True)
    category = html.escape(entry["category"], quote=True)
    slot = html.escape(entry["slot"], quote=True)

    if category:
        print(
            f'{prefix} id={entry["id"]} tt_id={entry["tt_id"]} '
            f'slot={slot} category="{category}" title="{title}"'
        )
    else:
        print(
            f'{prefix} id={entry["id"]} tt_id={entry["tt_id"]} '
            f'slot={slot} title="{title}"'
        )

old_entries = extract_entries(old_path)
new_entries = extract_entries(new_path)

old_ids = {entry["id"] for entry in old_entries}
new_ids = {entry["id"] for entry in new_entries}

removed = [entry for entry in old_entries if entry["id"] not in new_ids]
added = [entry for entry in new_entries if entry["id"] not in old_ids]

print(
    f"BLOG_ROTATION_SUMMARY old_count={len(old_entries)} "
    f"new_count={len(new_entries)} removed_count={len(removed)} added_count={len(added)}"
)

for entry in removed[:expected_count]:
    print_entry("BLOG_REMOVED", entry)

for entry in added[:expected_count]:
    print_entry("BLOG_ADDED", entry)

if len(removed) == 0 and len(added) == 0 and len(new_entries) > 0:
    print("BLOG_ROTATION_STATUS unchanged=true reason=already_current_or_same_rotation")
    for entry in new_entries:
        print_entry("BLOG_CURRENT", entry)

if len(removed) != expected_count or len(added) != expected_count:
    print(
        f"BLOG_ROTATION_NOTICE expected_removed={expected_count} actual_removed={len(removed)} "
        f"expected_added={expected_count} actual_added={len(added)}"
    )
PY
