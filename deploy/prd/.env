APP_SLUG=www
# <blank> means this public site is not using change-management environment suffixing.
DEPLOY_ENV=prd
RUNTIME_ADAPTER_CODE=static-github
REPO_ROOT=${PWD}
CONTAINER_ROOT="/workspace"
STACK=${APP_SLUG}
LOCAL_DOMAIN=etal.solutions

# ------------------------------
# anything below this line probably should not be edited manually
# ------------------------------
ENV_ROOT=${REPO_ROOT}
SITE_ROOT=${ENV_ROOT}/www
SITE_DIR=${SITE_ROOT}
LOG_DIR=${REPO_ROOT}/logs

APP_HOST=${STACK}.${LOCAL_DOMAIN}
URI_SCHEME=https:
SITE_URL=${URI_SCHEME}//${APP_HOST}
PUBLIC_BROWSER_CONFIG_KEYS=SITE_URL
PUBLIC_BROWSER_CONFIG_PATH=${SITE_DIR}/config.public.json

SITE_BRAND_NAME="Et al Solutions LLC"
SITE_CONTACT_EMAIL=info@etalsolutions.tech
GTM_CONTAINER_ID=GTM-59XLJP3Q
GA4_MEASUREMENT_ID=G-B3YZ2HTFTL
ANALYTICS_NOTES="The site installs Google Tag Manager only. GA4/Google Tag should be configured inside the GTM container to avoid duplicate page_view events."
PAGESPEED_APIKEY=AIzaSyCiz7ukeHKQyMmf5vQnRaBdFgS2cc1oeEE
PM_STATIC_EXCLUDE_DIRS=capture

DEPLOYMENT_ID=www-1778610786
PROJECT_ID=www-1778610786

# ------------------------------
# Et al Solutions – EPC Tag Contract
# ------------------------------
CLIENT="Et al Solutions LLC"

# Ownership (logical, not personal)
OWNER_ALIAS=etalsolutions             # Allowed: etalsolutions | client-it | client-dev | vendor | other

# Control plane
MANAGED_BY=github              # Allowed: compose | k8s | terraform | manual | other

# Container lifecycle
LIFECYCLE=long-lived                  # Allowed: ephemeral | long-lived | job

# Data governance
DATA_CLASS=public               # Allowed: public | internal | confidential | regulated
DATA_LIFECYCLE=persistent             # Allowed: transient | persistent | archival
