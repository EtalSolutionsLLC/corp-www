#!/usr/bin/env python3
"""Render a registered site collection region to stdout."""
from __future__ import annotations

import argparse
import html
import json
import sys
from pathlib import Path
from typing import Any

SITE_ROOT = Path.cwd().resolve()
COLLECTIONS_ROOT = SITE_ROOT / "collections"


def esc(value: object) -> str:
    return html.escape(str(value or ""), quote=True)


def load_json(path: Path) -> Any:
    return json.loads(path.read_text(encoding="utf-8"))


def resolve_within(root: Path, relative_path: str, label: str) -> Path:
    candidate = (root / relative_path).resolve()
    try:
        candidate.relative_to(root.resolve())
    except ValueError as exc:
        raise ValueError(f"{label} escapes collection directory: {relative_path}") from exc
    return candidate



def render_collection_styles() -> str:
    links = ['    <link rel="stylesheet" href="collections/_system/collection.css" />']
    for collection_dir in sorted(
        path for path in COLLECTIONS_ROOT.iterdir() if path.is_dir() and path.name != "_system"
    ):
        manifest_path = collection_dir / "collection.json"
        if not manifest_path.is_file():
            raise ValueError(f"Collection directory has no manifest: {collection_dir}")
        manifest = load_json(manifest_path)
        collection_id = collection_dir.name
        if manifest.get("id") != collection_id:
            raise ValueError(f"Collection id mismatch in {manifest_path}")
        style_file = manifest.get("styleFile")
        if not isinstance(style_file, str) or not style_file:
            raise ValueError(f"Collection styleFile missing in {manifest_path}")
        style_path = resolve_within(collection_dir, style_file, "styleFile")
        if not style_path.is_file():
            raise ValueError(f"Collection stylesheet not found: {style_path}")
        href = style_path.relative_to(SITE_ROOT).as_posix()
        links.append(f'    <link rel="stylesheet" href="{esc(href)}" />')
    return "\n".join(links) + "\n"

def collection_paths(collection_id: str) -> tuple[Path, dict[str, Any], list[dict[str, Any]]]:
    collection_dir = (COLLECTIONS_ROOT / collection_id).resolve()
    if collection_dir.parent != COLLECTIONS_ROOT.resolve():
        raise ValueError(f"Invalid collection id: {collection_id}")
    manifest_path = collection_dir / "collection.json"
    manifest = load_json(manifest_path)
    if manifest.get("id") != collection_id:
        raise ValueError(f"Collection id mismatch in {manifest_path}")
    data_file = manifest.get("dataFile")
    if not isinstance(data_file, str) or not data_file:
        raise ValueError(f"Collection dataFile missing in {manifest_path}")
    data_path = resolve_within(collection_dir, data_file, "dataFile")
    items = load_json(data_path)
    if not isinstance(items, list):
        raise ValueError(f"Collection items must be an array: {data_path}")
    return collection_dir, manifest, sorted(items, key=lambda item: (item.get("sortOrder", 0), str(item.get("id", ""))))


def action_html(action: dict[str, Any] | None, css_class: str = "hero-cta") -> str:
    if not action:
        return ""
    href = esc(action.get("href"))
    label = esc(action.get("label"))
    attrs = ""
    if action.get("openInNewTab"):
        attrs = ' target="_blank" rel="noopener noreferrer"'
    return f'<a class="{css_class}" href="{href}"{attrs}>{label}</a>'


def tags_html(tags: list[Any]) -> str:
    if not tags:
        return ""
    values = "\n".join(f"              <li>{esc(tag)}</li>" for tag in tags)
    return f'''            <ul class="catalog-tag-list" aria-label="Tags">
{values}
            </ul>'''


def attributes_html(attributes: list[dict[str, Any]]) -> str:
    if not attributes:
        return ""
    cards = []
    for attribute in attributes:
        cards.append(
            "\n".join(
                [
                    '              <div class="catalog-attribute">',
                    f'                <strong>{esc(attribute.get("title"))}</strong>',
                    f'                <p>{esc(attribute.get("body"))}</p>',
                    "              </div>",
                ]
            )
        )
    return '            <div class="catalog-attribute-grid">\n' + "\n".join(cards) + "\n            </div>"


def price_html(item: dict[str, Any], indent: str = "            ") -> str:
    price = item.get("price")
    if not price:
        return ""
    note = item.get("priceNote")
    note_html = f" <small>{esc(note)}</small>" if note else ""
    return f'{indent}<div class="catalog-price">{esc(price)}{note_html}</div>'


def render_catalog_item(item: dict[str, Any], default_slug: str) -> str:
    slug = str(item.get("slug") or item.get("id") or "")
    featured = slug == default_slug or item.get("status") == "featured"
    item_class = "catalog-carousel-item is-featured" if featured else "catalog-carousel-item"
    summary_class = "catalog-card catalog-panel catalog-panel-summary is-featured" if featured else "catalog-card catalog-panel catalog-panel-summary"
    title = item.get("title") or item.get("shortTitle") or slug
    short_title = item.get("shortTitle") or title
    subtitle = item.get("subtitle") or ""
    summary = item.get("summary") or ""
    detail_summary = item.get("detailSummary") or summary
    label = item.get("label") or ""
    logo = item.get("logo")
    logo_alt = item.get("logoAlt") or ""

    if logo:
        summary_header = "\n".join(
            [
                '            <div class="catalog-summary-brand-header">',
                f'              <span class="catalog-badge">{esc(label)}</span>',
                f'              <img class="catalog-summary-logo" src="{esc(logo)}" alt="{esc(logo_alt)}" />',
                "            </div>",
            ]
        )
        detail_media = f'            <img class="catalog-detail-logo" src="{esc(logo)}" alt="{esc(logo_alt)}" />'
    else:
        summary_header = f'            <span class="catalog-badge">{esc(label)}</span>'
        detail_media = price_html(item)

    summary_price = price_html(item)
    tags = tags_html(item.get("tags") or [])
    attrs = attributes_html(item.get("attributes") or [])
    action = action_html(item.get("primaryAction"))
    action_block = f'            <div class="catalog-actions">\n              {action}\n            </div>' if action else ""

    parts = [
        f'      <section class="{item_class}" data-collection-item data-collection-slug="{esc(slug)}" data-collection-title="{esc(short_title)}">',
        '        <div class="catalog-item-panels">',
        f'          <article class="{summary_class}" aria-label="{esc(title)} summary">',
        summary_header,
        f'            <h2>{esc(title)}</h2>',
        f'            <p class="catalog-subtitle">{esc(subtitle)}</p>',
        f'            <p>{esc(summary)}</p>',
    ]
    if summary_price:
        parts.append(summary_price)
    if tags:
        parts.append(tags)
    parts.extend(
        [
            "          </article>",
            f'          <aside class="catalog-detail-panel catalog-panel catalog-panel-detail" id="{esc(slug)}-details" aria-label="{esc(title)} details">',
            f'            <span class="catalog-badge">{esc(label)}</span>',
            f'            <h3>{esc(short_title)}</h3>',
            f'            <p class="catalog-subtitle">{esc(subtitle)}</p>',
        ]
    )
    if detail_media:
        parts.append(detail_media)
    parts.append(f'            <p class="catalog-detail-summary">{esc(detail_summary)}</p>')
    if attrs:
        parts.append(attrs)
    if action_block:
        parts.append(action_block)
    parts.extend(["          </aside>", "        </div>", "      </section>"])
    return "\n".join(parts)


def render_catalog_full(manifest: dict[str, Any], items: list[dict[str, Any]]) -> str:
    collection_id = str(manifest["id"])
    labels = manifest.get("labels") or {}
    default_slug = str(manifest.get("defaultItem") or next((item.get("slug") for item in items if item.get("status") == "featured"), items[0].get("slug", "")))
    rendered_items = "\n".join(render_catalog_item(item, default_slug) for item in items)
    return f'''      <section class="catalog-carousel collection collection--catalog" aria-label="{esc(collection_id.title())} collection" data-collection data-collection-id="{esc(collection_id)}" data-collection-mode="catalog" data-collection-config="/collections/{esc(collection_id)}/collection.json" data-collection-carousel data-collection-default="{esc(default_slug)}">

        <div class="catalog-carousel-instructions" data-collection-nav data-newer-label="{esc(labels.get('newer', 'Previous'))}" data-previous-label="{esc(labels.get('previous', 'Next'))}" data-end-label="{esc(labels.get('end', 'End'))}" data-detail-label="{esc(labels.get('detail', 'Details'))}" data-summary-label="{esc(labels.get('summary', 'Summary'))}">

          <span class="catalog-scroll-hint">{esc(labels.get('scrollHint', 'Scroll sideways through items.'))}</span>

          <span data-collection-newer-slot><span class="catalog-direction-empty"></span></span>

          <span data-collection-previous-slot><span class="catalog-direction-empty"></span></span>

        </div>

        <div class="catalog-carousel-track" data-collection-track>
{rendered_items}
        </div>

      </section>
'''



def render_catalog_section(manifest: dict[str, Any], items: list[dict[str, Any]]) -> str:
    collection_id = str(manifest["id"])
    presentation = manifest.get("presentation") or {}
    theme = str(presentation.get("theme") or "light")
    if theme not in {"light", "dark"}:
        raise ValueError(f"Unsupported catalog theme for {collection_id}: {theme}")

    extra_classes = presentation.get("extraClasses") or []
    if not isinstance(extra_classes, list) or not all(isinstance(value, str) for value in extra_classes):
        raise ValueError(f"presentation.extraClasses must be an array of strings for {collection_id}")

    section_classes = [
        f"section-{theme}",
        "panel",
        "catalog-home-section",
        *extra_classes,
        "pm-viewport-target",
        "pm-scroll-target",
    ]
    title_id = f"{collection_id}-title"
    top_id = f"{collection_id}-top"
    content_id = str(presentation.get("contentId") or f"{collection_id}-items")
    content_label = str(presentation.get("contentLabel") or f"{collection_id.title()} items")
    kicker_class = "section-kicker light"

    return f'''      <section class="{' '.join(section_classes)}" id="{esc(collection_id)}" data-theme="{esc(theme)}" aria-labelledby="{esc(title_id)}">
        <div class="container catalog-page-layout pm-viewport-target__inner">
          <section class="catalog-page-head" id="{esc(top_id)}" aria-labelledby="{esc(title_id)}">
            <span class="{kicker_class}">{esc(presentation.get('kicker') or collection_id.title())}</span>
            <h2 id="{esc(title_id)}">{esc(presentation.get('title'))}</h2>
            <p>{esc(presentation.get('summary'))}</p>
          </section>

          <div class="catalog-full-list" id="{esc(content_id)}" aria-label="{esc(content_label)}">
{render_catalog_full(manifest, items).rstrip()}
          </div>
        </div>
      </section>
'''

def render_catalog_hero(manifest: dict[str, Any], items: list[dict[str, Any]]) -> str:
    item = next((candidate for candidate in items if candidate.get("status") == "featured"), items[0])
    labels = manifest.get("labels") or {}
    href = manifest.get("sectionHref") or "/#promotions"
    detail_id = f"{item.get('slug') or item.get('id')}-details"
    price = item.get("price")
    price_row = f'              <span>Price: <strong>{esc(price)}</strong></span>' if price else ""
    return f'''          <aside class="catalog-hero-card collection collection--catalog" aria-label="Featured {esc(manifest.get('id'))} item" data-collection data-collection-id="{esc(manifest.get('id'))}" data-collection-mode="catalog" data-collection-config="/collections/{esc(manifest.get('id'))}/collection.json">
            <span class="catalog-hero-kicker">{esc(item.get('label') or 'Featured')}</span>
            <h2>{esc(item.get('title'))}</h2>
            <div class="catalog-hero-meta" aria-label="Collection item details">
              <span>{esc(item.get('audience'))}</span>
{price_row}
            </div>
            <p>{esc(item.get('summary'))}</p>
            <a class="catalog-hero-cta action action-primary" href="{esc(href)}" data-collection-detail-open="{esc(detail_id)}">{esc(labels.get('heroCta', 'View Details'))}</a>
          </aside>
'''


def render_publication(collection_dir: Path, manifest: dict[str, Any], items: list[dict[str, Any]]) -> str:
    selection_cfg = manifest.get("selection") or {}
    selection_path = resolve_within(
        collection_dir,
        str(selection_cfg.get("outputFile") or "generated/selection.json"),
        "selection.outputFile",
    )
    selection = load_json(selection_path)
    visible = selection.get("visibleItems") or []
    if not visible:
        raise ValueError(f"No visible items in {selection_path}")
    labels = manifest.get("labels") or {}
    presentation = manifest.get("presentation") or {}
    collection_id = str(manifest["id"])
    featured, supporting = visible[0], visible[1:]

    title_lines = "\n".join(f"            <span>{esc(line)}</span>" for line in presentation.get("titleLines") or [])
    action = action_html(presentation.get("primaryAction"), "thread-topic-cta action action-primary")
    supporting_html = []
    for item in supporting:
        supporting_html.append(
            f'''            <article class="thread-post-card" data-post-category="{esc(item.get('category'))}" data-collection-item data-collection-item-id="{esc(item.get('id'))}" data-collection-slug="{esc(item.get('slug'))}" data-collection-slot="{esc(item.get('slot'))}">
              <div class="thread-post-meta">
                <span>{esc(item.get('category'))}</span>
                <span>{esc(item.get('status'))}</span>
              </div>
              <h3>{item.get('title_html') or esc(item.get('title'))}</h3>
              <p>{item.get('excerpt_html') or esc(item.get('excerpt'))}</p>
              <a class="thread-post-link" href="{esc(item.get('url'))}" data-collection-open-item="{esc(item.get('id'))}">{esc(labels.get('openItem', 'Read article →'))}</a>
            </article>'''
        )

    return f'''  <section class="thread-blog panel pm-viewport-target pm-scroll-target collection collection--publication" id="blog" data-theme="light" aria-labelledby="thread-blog-title" data-collection data-collection-id="{esc(collection_id)}" data-collection-mode="publication" data-collection-config="/collections/{esc(collection_id)}/collection.json">

    <div class="container pm-viewport-target__inner">
      <div class="thread-blog-showcase">
        <div class="thread-blog-masthead">
          <div class="thread-blog-logo-wrap" aria-label="{esc(presentation.get('brand'))}">
            <img class="thread-blog-logo" src="{esc(presentation.get('logo'))}" alt="{esc(presentation.get('logoAlt'))}" />
          </div>
          <span class="thread-blog-kicker">{esc(presentation.get('kicker'))}</span>
          <h2 id="thread-blog-title" class="thread-blog-title">
{title_lines}
          </h2>
          <p class="thread-blog-summary">{esc(presentation.get('summary'))}</p>
          <div class="thread-blog-actions">
            {action}
          </div>
        </div>

        <div class="thread-post-layout" aria-label="{esc(presentation.get('brand'))} article list">
          <article class="thread-featured-post" aria-label="Featured article" data-collection-item data-collection-item-id="{esc(featured.get('id'))}" data-collection-slug="{esc(featured.get('slug'))}" data-collection-slot="{esc(featured.get('slot'))}">
            <div class="thread-post-meta">
              <span>{esc(labels.get('featured', 'Featured'))}</span>
              <span>{esc(featured.get('category'))}</span>
            </div>
            <h3>{featured.get('title_html') or esc(featured.get('title'))}</h3>
            <p>{featured.get('excerpt_html') or esc(featured.get('excerpt'))}</p>
            <a class="thread-post-link" href="{esc(featured.get('url'))}" data-collection-open-item="{esc(featured.get('id'))}">{esc(labels.get('openFeatured', 'Read this article →'))}</a>
          </article>

          <div class="thread-post-grid">
{chr(10).join(supporting_html)}
          </div>
        </div>

        <dialog class="thread-article-modal" data-collection-modal aria-labelledby="thread-article-modal-title">
          <div class="thread-article-modal-shell">
            <button class="thread-article-modal-close modal-close-circle" type="button" data-collection-modal-close aria-label="{esc(labels.get('close', 'Close article'))}">×</button>
            <span class="thread-blog-kicker">{esc(presentation.get('brand'))}</span>
            <p class="thread-article-modal-meta" data-collection-modal-meta></p>
            <h3 id="thread-article-modal-title" data-collection-modal-title></h3>
            <div class="thread-article-modal-body" data-collection-modal-body></div>
          </div>
        </dialog>
      </div>
    </div>
  </section>
'''


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("collection_id")
    parser.add_argument("region")
    args = parser.parse_args()

    if args.collection_id == "_system" and args.region == "styles":
        sys.stdout.write(render_collection_styles())
        return 0

    collection_dir, manifest, items = collection_paths(args.collection_id)
    mode = manifest.get("mode")
    if mode == "catalog" and args.region == "section":
        output = render_catalog_section(manifest, items)
    elif mode == "catalog" and args.region == "heroTeaser":
        output = render_catalog_hero(manifest, items)
    elif mode == "publication" and args.region == "section":
        output = render_publication(collection_dir, manifest, items)
    else:
        raise ValueError(f"Unsupported collection region: {args.collection_id}/{args.region}")
    sys.stdout.write(output.rstrip() + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
