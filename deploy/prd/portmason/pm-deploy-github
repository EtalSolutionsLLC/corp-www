#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]:-${0:-}}")}"
export CUR_SCRIPT

: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" "$@"

# For GitHub Pages, deploy is normally handled by GitHub Actions. Locally this
# prepares the static artifact directory and generated browser config.
github_pages_prepare
log INFO "GitHub Pages static artifact ready: ${GITHUB_PAGES_BUILD_DIR}"
