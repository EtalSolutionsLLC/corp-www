#!/usr/bin/env bash
# Purpose: Capture a project workspace using source-of-truth directory boundaries.
# Behavior: Best-effort. Capture failures are logged and do not stop unrelated sections.
#
# Archive layout:
#   <stack>_<timestamp>/
#   ├── project/                         authoritative project tree
#   ├── ops-and-sops/ops/portmason/     canonical Portmason source
#   ├── traefik/                         Traefik source tree
#   ├── git/                             Git CLI output
#   ├── docker/                          Docker/Compose CLI output
#   └── capture-manifest.txt             resolved sources and capture status
#
# The staged project/portmason runtime copy is intentionally excluded from project/.
# /usr capture is intentionally omitted until its ownership and restore contract are defined.

set -u
set -o pipefail || true

script_name="${script_name:-$(basename "${BASH_SOURCE[0]}")}"

ensure_portmason_share() {
  [[ -n "${PORTMASON_SHARE:-}" ]] && return 0

  local target="pm-helpers"
  local here parent default="/usr/local/share/portmason/bin"

  here="$(pwd -P)"
  parent="$(cd .. && pwd -P)"

  if [[ -f "${here}/${target}" ]]; then
    PORTMASON_SHARE="${here}"
    export PORTMASON_SHARE
    return 0
  fi

  if [[ -f "${parent}/${target}" ]]; then
    PORTMASON_SHARE="${parent}"
    export PORTMASON_SHARE
    return 0
  fi

  local d
  for d in "${parent}"/*; do
    [[ -d "$d" ]] || continue
    [[ "$(cd "$d" && pwd -P)" == "$here" ]] && continue
    if [[ -f "${d}/${target}" ]]; then
      PORTMASON_SHARE="${d}"
      export PORTMASON_SHARE
      return 0
    fi
  done

  if [[ -f "${default}/${target}" ]]; then
    PORTMASON_SHARE="${default}"
    export PORTMASON_SHARE
    return 0
  fi

  printf 'ERROR: PORTMASON_SHARE unset and could not find %s in %s, %s, adjacent directories, or %s\n' \
    "$target" "$here" "$parent" "$default" >&2
  return 2
}

ensure_portmason_share || exit $?
export CUR_SCRIPT="$script_name"
export MINIMAL="${MINIMAL:-1}"
# shellcheck disable=SC1090
. "${PORTMASON_SHARE}/pm-helpers"

# pm-helpers enables errexit. This capture utility is intentionally best-effort.
set +e

try() {
  local desc="${1:?description required}"
  shift

  log "$desc"
  "$@"
  local rc=$?

  if (( rc != 0 )); then
    warn "$desc failed with exit code $rc"
  fi

  return 0
}

isfile() { [[ -f "$1" ]]; }
writable_dir() { [[ -d "$1" && -w "$1" ]]; }

resolve_existing_dir() {
  local path="${1:-}"
  [[ -n "$path" && -d "$path" ]] || return 1
  (cd "$path" && pwd -P)
}

# -----------------------------
# Arguments
# -----------------------------
COPY_TARGET="${COPY_TARGET:-}"
SHOW_WHICH=0

while (( "$#" )); do
  case "${1:-}" in
    --copy)
      shift || true
      COPY_TARGET="${1:-}"
      ;;
    --copy-public)
      COPY_TARGET="/mnt/c/Users/Public/Desktop"
      ;;
    --which)
      SHOW_WHICH=1
      ;;
    --copy-target)
      shift || true
      COPY_TARGET="${1:-}"
      ;;
    *)
      warn "Unknown arg: $1 (ignored)"
      ;;
  esac
  shift || true
done

if (( SHOW_WHICH == 1 )); then
  echo "which: $(command -v "$script_name" 2>/dev/null || true)"
fi

# -----------------------------
# Inputs and source boundaries
# -----------------------------
PROJECT_ROOT="${PROJECT_ROOT:-$PWD}"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$HOME/code}"
OPS_AND_SOPS_ROOT="${OPS_AND_SOPS_ROOT:-${WORKSPACE_ROOT}/ops-and-sops}"
PORTMASON_SOURCE_DIR="${PORTMASON_SOURCE_DIR:-${OPS_AND_SOPS_ROOT}/ops/portmason}"
TRAEFIK_DIR="${TRAEFIK_DIR:-${WORKSPACE_ROOT}/traefik}"

if resolved="$(resolve_existing_dir "$PROJECT_ROOT")"; then
  PROJECT_ROOT="$resolved"
else
  err "Project root does not exist: $PROJECT_ROOT"
  exit 1
fi

if resolved="$(resolve_existing_dir "$OPS_AND_SOPS_ROOT")"; then
  OPS_AND_SOPS_ROOT="$resolved"
fi

if resolved="$(resolve_existing_dir "$PORTMASON_SOURCE_DIR")"; then
  PORTMASON_SOURCE_DIR="$resolved"
fi

if resolved="$(resolve_existing_dir "$TRAEFIK_DIR")"; then
  TRAEFIK_DIR="$resolved"
fi

CURRENT_DIR_NAME="$(basename "$PROJECT_ROOT")"
STACK="${STACK:-$CURRENT_DIR_NAME}"
CAPTURE_ROOT="${CAPTURE_ROOT:-${PROJECT_ROOT}/capture}"

ts="$(date +'%Y-%m-%dT%H-%M-%S%z')"
RUN_NAME="${STACK}_${ts}"
RUN_DIR="${CAPTURE_ROOT}/${RUN_NAME}"
ARCHIVE_PATH="${CAPTURE_ROOT}/${RUN_NAME}.tar.gz"
ARCHIVE_BASENAME="$(basename "$ARCHIVE_PATH")"

log "PROJECT_ROOT:          $PROJECT_ROOT"
log "OPS_AND_SOPS_ROOT:     $OPS_AND_SOPS_ROOT"
log "PORTMASON_SOURCE_DIR:  $PORTMASON_SOURCE_DIR"
log "TRAEFIK_DIR:           $TRAEFIK_DIR"
log "PORTMASON_SHARE:       $PORTMASON_SHARE"
log "STACK:                 $STACK"
log "CAPTURE_ROOT:          $CAPTURE_ROOT"
log "RUN_DIR:               $RUN_DIR"
log "ARCHIVE:               $ARCHIVE_PATH"
[[ -n "$COPY_TARGET" ]] && log "COPY_TARGET:           $COPY_TARGET"

mkdir -p "$RUN_DIR" || {
  err "Could not create run directory: $RUN_DIR"
  exit 1
}

MANIFEST="$RUN_DIR/capture-manifest.txt"
cat > "$MANIFEST" <<MANIFEST_EOF
capture_format_version=2
created_at=$ts
stack=$STACK
project_source=$PROJECT_ROOT
project_destination=project
portmason_source=$PORTMASON_SOURCE_DIR
portmason_destination=ops-and-sops/ops/portmason
traefik_source=$TRAEFIK_DIR
traefik_destination=traefik
git_capture=cli-output
docker_capture=cli-output
usr_capture=unresolved-omitted
runtime_portmason_share=$PORTMASON_SHARE
MANIFEST_EOF

# -----------------------------
# Project source tree
# -----------------------------
PROJECT_OUT="$RUN_DIR/project"
mkdir -p "$PROJECT_OUT" || warn "Could not create $PROJECT_OUT"

try "Copying authoritative project tree" rsync -aL --delete \
  --exclude '/state/' \
  --exclude '/capture/' \
  --exclude '/.git/' \
  --exclude '/portmason/' \
  --exclude 'node_modules/' \
  --exclude 'dist/' \
  --exclude 'build/' \
  --exclude '*.log_archive' \
  "$PROJECT_ROOT/" "$PROJECT_OUT/"

# -----------------------------
# Canonical Portmason source
# -----------------------------
PORTMASON_OUT="$RUN_DIR/ops-and-sops/ops/portmason"

if [[ -d "$PORTMASON_SOURCE_DIR" ]]; then
  mkdir -p "$PORTMASON_OUT" || warn "Could not create $PORTMASON_OUT"
  try "Copying canonical Portmason source" rsync -aL --delete \
    --exclude '/.git/' \
    --exclude '/capture/' \
    --exclude '/state/' \
    --exclude '__pycache__/' \
    --exclude '*.pyc' \
    --exclude '*.log_archive' \
    "$PORTMASON_SOURCE_DIR/" "$PORTMASON_OUT/"
else
  warn "Canonical Portmason source not found: $PORTMASON_SOURCE_DIR"
  printf 'portmason_capture_status=missing\n' >> "$MANIFEST"
fi

# -----------------------------
# Traefik source tree
# -----------------------------
TRAEFIK_OUT="$RUN_DIR/traefik"

if [[ -d "$TRAEFIK_DIR" ]]; then
  mkdir -p "$TRAEFIK_OUT" || warn "Could not create $TRAEFIK_OUT"
  try "Copying Traefik source tree" rsync -aL --delete \
    --exclude '/.git/' \
    --exclude '/capture/' \
    --exclude '/state/' \
    --exclude '__pycache__/' \
    --exclude '*.pyc' \
    --exclude '*.log_archive' \
    "$TRAEFIK_DIR/" "$TRAEFIK_OUT/"
else
  warn "Traefik source directory not found: $TRAEFIK_DIR"
  printf 'traefik_capture_status=missing\n' >> "$MANIFEST"
fi

# -----------------------------
# Docker/Compose CLI snapshot
# -----------------------------
CONTAINER_CLI=""
if command -v docker >/dev/null 2>&1; then
  CONTAINER_CLI="docker"
elif command -v podman >/dev/null 2>&1; then
  CONTAINER_CLI="podman"
fi

COMPOSE_FILE_FOUND=0
if [[ -f "$PROJECT_ROOT/docker-compose.yml" || -f "$PROJECT_ROOT/compose.yml" ]]; then
  COMPOSE_FILE_FOUND=1
fi

if [[ -n "$CONTAINER_CLI" && "$COMPOSE_FILE_FOUND" -eq 1 ]]; then
  DOCKER_OUT="$RUN_DIR/docker"
  mkdir -p "$DOCKER_OUT" || warn "Could not create $DOCKER_OUT"

  try "$CONTAINER_CLI compose ps" bash -lc \
    "cd '$PROJECT_ROOT' && '$CONTAINER_CLI' compose ps > '$DOCKER_OUT/compose-ps.txt' 2>&1"
  try "$CONTAINER_CLI network ls" bash -lc \
    "'$CONTAINER_CLI' network ls > '$DOCKER_OUT/network-ls.txt' 2>&1"
  try "$CONTAINER_CLI volume ls" bash -lc \
    "'$CONTAINER_CLI' volume ls > '$DOCKER_OUT/volume-ls.txt' 2>&1"
  try "$CONTAINER_CLI ps --all" bash -lc \
    "'$CONTAINER_CLI' ps -a > '$DOCKER_OUT/ps-a.txt' 2>&1"
  try "$CONTAINER_CLI images" bash -lc \
    "'$CONTAINER_CLI' images > '$DOCKER_OUT/images.txt' 2>&1"
else
  log "Skipping Docker/Compose CLI capture (runtime or compose file unavailable)."
fi

# -----------------------------
# Git CLI snapshot
# -----------------------------
if [[ -d "$PROJECT_ROOT/.git" ]]; then
  GIT_OUT="$RUN_DIR/git"
  mkdir -p "$GIT_OUT" || warn "Could not create $GIT_OUT"

  try "Capturing Git commit" bash -lc \
    "cd '$PROJECT_ROOT' && git rev-parse --short HEAD > '$GIT_OUT/commit.txt' 2>&1"
  try "Capturing Git status" bash -lc \
    "cd '$PROJECT_ROOT' && git status --porcelain=v1 > '$GIT_OUT/status.txt' 2>&1"
  try "Capturing Git log" bash -lc \
    "cd '$PROJECT_ROOT' && git log -20 --oneline > '$GIT_OUT/log.txt' 2>&1"
  try "Capturing Git diff" bash -lc \
    "cd '$PROJECT_ROOT' && git diff > '$GIT_OUT/diff.txt' 2>&1"
else
  log "Skipping Git CLI capture (no .git directory)."
fi

# -----------------------------
# /usr status
# -----------------------------
log "Skipping /usr capture: ownership and restore contract are unresolved."

# -----------------------------
# Archive
# -----------------------------
if [[ -d "$CAPTURE_ROOT" && -w "$CAPTURE_ROOT" ]]; then
  log "Creating archive: $ARCHIVE_PATH"
  (
    cd "$CAPTURE_ROOT" && tar -czf "$ARCHIVE_PATH" "$RUN_NAME"
  ) || warn "Failed to create archive at $ARCHIVE_PATH"
else
  warn "Capture directory is not writable; skipping archive: $CAPTURE_ROOT"
fi

# -----------------------------
# Optional copy
# -----------------------------
if [[ -n "$COPY_TARGET" ]] && isfile "$ARCHIVE_PATH"; then
  if writable_dir "$COPY_TARGET"; then
    try "Copying archive to $COPY_TARGET" cp -fL \
      "$ARCHIVE_PATH" "$COPY_TARGET/$ARCHIVE_BASENAME"
  else
    warn "Copy target not writable: $COPY_TARGET"
    for alt in "/mnt/c/Users/Public/Desktop" "$HOME/Desktop"; do
      if writable_dir "$alt"; then
        try "Fallback copy to $alt" cp -fL \
          "$ARCHIVE_PATH" "$alt/$ARCHIVE_BASENAME"
        break
      fi
    done
  fi
fi

log "Capture complete."
echo "Run directory:  $RUN_DIR"
isfile "$ARCHIVE_PATH" && echo "Archive:        $ARCHIVE_PATH"
[[ -n "$COPY_TARGET" ]] && echo "Copy target:    $COPY_TARGET (best-effort)"
exit 0
