#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]:-${0:-}}")}" 
export CUR_SCRIPT
: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" "$@"

is_deploy_snapshot_dir() {
    [[ "$(basename -- "$(dirname -- "$PWD")")" == "deploy" ]]
}

main() {
    export PROJECT_SERVICES=

    local deploy_sync_active=0
    local deploy_sync_force=0
    local sync_owner_host=""
    local -a sync_args=(--prepare)

    case "${PM_DEPLOY_SYNC_FORCE:-}" in
        1|true|TRUE|yes|YES|on|ON)
            deploy_sync_force=1
            ;;
    esac

    [[ ${REFRESH_FROM_ROOT:-0} == 1 || ${FORCE_DEPLOY_SYNC:-0} == 1 ]] && deploy_sync_force=1

    if is_deploy_snapshot_dir; then
        sync_owner_host="$(hostname 2>/dev/null || printf 'unknown')"
        if [[ "$deploy_sync_force" -eq 1 ]]; then
            sync_args+=(--force)
            log INFO "pm-setup: explicit deploy refresh requested"
        fi
        PM_DEPLOY_SYNC_OWNER_PID="$$" \
        PM_DEPLOY_SYNC_OWNER_HOST="$sync_owner_host" \
            "${PORTMASON_SHARE}/pm-sync-deploy-from-root" "${sync_args[@]}"
        deploy_sync_active=1
    elif [[ "$deploy_sync_force" -eq 1 ]]; then
        die "--refresh-from-root is only valid from deploy/<env>"
    fi

    #"${PORTMASON_SHARE}/pm-generate-config"
    log INFO "pm-setup: generating project configuration"
log INFO "pm-setup: ENV_FILE=${ENV_FILE:-<unset>}"
log INFO "pm-setup: SITE_DIR=${SITE_DIR:-<unset>}"
log INFO "pm-setup: generator=${PORTMASON_SHARE}/pm-generate-config"

if "${PORTMASON_SHARE}/pm-generate-config"; then
    log INFO "pm-setup: project configuration generated"
else
    rc=$?
    fatal_error "pm-generate-config failed with exit code ${rc}" "$rc"
fi

    stage_portmason "archive" "cagent" "*cosign*" "*log" # Exclude archive/, cagent, cosign files, log files

    # run the adapter provisioning script, if it exists
    local file="${PORTMASON_SHARE}/pm-provision-${ADAPTER_CODE}"
    [[ -r "$file" ]] && . "$file" "$@"

    # run the optional adapter setup script
    file="${PORTMASON_SHARE}/pm-setup-${ADAPTER_CODE}"
    [[ -r "$file" ]] && . "$file" "$@"

    # run the optional runtime setup script
    file="${PORTMASON_SHARE}/pm-setup-${RUNTIME_CODE}"
    [[ -r "$file" ]] && . "$file" "$@"

    # if a custom setup file exists, it must handle all deployment tasks for the project,
    # Otherwise, run the standard runtime deploy followed by the standard adapter deploy
    file="${SCRIPT_DIR}/setup"
    if [[ -r "$file" ]]; then
        . "$file" "$@"
        local rc=$?

        case "$rc" in
            0)
                log "Success."
                ;;
            1)
                die "General error:" "$rc"
                ;;
            2)
                die "Misuse of shell builtins or command-specific code." "$rc"
                ;;
            *)
                fatal_error "Unexpected error code:" "$rc"
                ;;
        esac
    else
        # run the optional runtime deploy script
        file="${PORTMASON_SHARE}/pm-deploy-${RUNTIME_CODE}"
        [[ -r "$file" ]] && . "$file" "$@"

        # run the optional adapter deploy script
        if declare -F pm_bridge_deploy >/dev/null 2>&1; then
            log INFO "pm-setup: using bridge deploy hook: pm_bridge_deploy"
            pm_bridge_deploy "$@"
        else
            file="${PORTMASON_SHARE}/pm-deploy-${ADAPTER_CODE}"
            [[ -r "$file" ]] && . "$file" "$@"
        fi
    fi

    if [[ "$deploy_sync_active" -eq 1 ]]; then
        PM_DEPLOY_SYNC_OWNER_PID="$$" \
        PM_DEPLOY_SYNC_OWNER_HOST="$sync_owner_host" \
            "${PORTMASON_SHARE}/pm-sync-deploy-from-root" --finalize
    fi
}

pm_setup_arg REFRESH_FROM_ROOT "--refresh-from-root" export
pm_setup_arg FORCE_DEPLOY_SYNC "--force-deploy-sync" export
pm_commit_args "$@"

main "$@"
