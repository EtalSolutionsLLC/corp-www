#!/usr/bin/env python3
"""Render Portmason static-site partial blocks.

Marker model:

    <!-- PM:TAGNAME -->
    existing managed content
    <!-- /PM:TAGNAME -->

Resolution order for TAGNAME:

    1. partials/TAGNAME.html
    2. partials/hooks/TAGNAME

The utility is intentionally project-agnostic. SITE_DIR points at the static
site root and defaults to the current working directory. By default every HTML
page under SITE_DIR is processed except partials, archive/runtime folders, and
other generated/control directories. Specific pages may be supplied as args.
"""
from __future__ import annotations

import argparse
import os
import re
import stat
import subprocess
import sys
from pathlib import Path
from typing import Iterable

BLOCK_RE = re.compile(
    r"<!--\s*PM:([A-Za-z0-9_-]+)\s*-->(.*?)<!--\s*/PM:\1\s*-->",
    re.DOTALL,
)

EXCLUDED_DIR_NAMES = {
    ".git",
    "archive",
    "capture",
    "logs",
    "partials",
    "portmason",
    "tests",
    "deploy",
    "__pycache__",
}


def normalize_tag(tag: str) -> str:
    return tag.strip().lower()


def is_executable(path: Path) -> bool:
    return path.is_file() and bool(path.stat().st_mode & stat.S_IXUSR)


def page_is_excluded(path: Path, site_dir: Path) -> bool:
    try:
        rel = path.relative_to(site_dir)
    except ValueError:
        return True
    return any(part in EXCLUDED_DIR_NAMES for part in rel.parts[:-1])


def discover_pages(site_dir: Path) -> list[Path]:
    pages: list[Path] = []
    for path in sorted(site_dir.rglob("*.html")):
        if page_is_excluded(path, site_dir):
            continue
        pages.append(path)
    return pages


def resolve_page_args(site_dir: Path, args: Iterable[str]) -> list[Path]:
    pages: list[Path] = []
    for raw in args:
        candidate = Path(raw)
        if not candidate.is_absolute():
            candidate = site_dir / candidate
        candidate = candidate.resolve()
        if not candidate.is_file():
            raise FileNotFoundError(f"HTML page not found: {candidate}")
        if candidate.suffix.lower() != ".html":
            raise ValueError(f"Not an HTML page: {candidate}")
        if page_is_excluded(candidate, site_dir):
            raise ValueError(f"Refusing to process excluded page: {candidate}")
        pages.append(candidate)
    return pages


class PartialRenderer:
    def __init__(self, site_dir: Path) -> None:
        self.site_dir = site_dir
        self.partials_dir = site_dir / "partials"
        self.hooks_dir = self.partials_dir / "hooks"

    def render_tag(self, tag: str) -> str:
        normalized = normalize_tag(tag)
        partial = self.partials_dir / f"{normalized}.html"
        hook = self.hooks_dir / normalized

        if partial.is_file():
            return partial.read_text(encoding="utf-8").rstrip() + "\n"

        if is_executable(hook):
            result = subprocess.run(
                [str(hook)],
                cwd=str(self.site_dir),
                text=True,
                stdout=subprocess.PIPE,
                stderr=None,
                check=False,
            )
            if result.returncode != 0:
                raise RuntimeError(
                    f"Hook failed for PM:{tag}: {hook} exited {result.returncode}"
                )
            return result.stdout.rstrip() + "\n"

        raise FileNotFoundError(
            f"No partial or hook found for PM:{tag}; expected {partial} or {hook}"
        )

    def process_page(self, page: Path) -> int:
        source = page.read_text(encoding="utf-8")

        def replace_block(match: re.Match[str]) -> str:
            tag = match.group(1)
            rendered = self.render_tag(tag)
            return f"<!-- PM:{tag} -->\n{rendered}<!-- /PM:{tag} -->"

        rendered, count = BLOCK_RE.subn(replace_block, source)
        if count == 0:
            return 0

        if rendered != source:
            page.write_text(rendered, encoding="utf-8")
            os.chmod(page, 0o644)

        return count


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Render PM partial blocks in static HTML pages."
    )
    parser.add_argument(
        "pages",
        nargs="*",
        help="Optional page paths relative to SITE_DIR. Defaults to all HTML pages.",
    )
    parser.add_argument(
        "--site-dir",
        default=os.environ.get("SITE_DIR", os.getcwd()),
        help="Static site root. Defaults to SITE_DIR or current directory.",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    ns = parser.parse_args(argv)

    site_dir = Path(ns.site_dir).resolve()
    if not site_dir.is_dir():
        print(f"ERROR: SITE_DIR not found or not a directory: {site_dir}", file=sys.stderr)
        return 1

    try:
        pages = resolve_page_args(site_dir, ns.pages) if ns.pages else discover_pages(site_dir)
        renderer = PartialRenderer(site_dir)
        total_blocks = 0
        touched_pages = 0

        for page in pages:
            count = renderer.process_page(page)
            if count:
                total_blocks += count
                touched_pages += 1
                print(f"Processed {count} partial block(s): {page.relative_to(site_dir)}")

        if total_blocks == 0:
            print(f"No PM partial blocks found in {site_dir}")
        else:
            print(f"Processed {total_blocks} partial block(s) across {touched_pages} page(s).")

        return 0
    except Exception as exc:  # intentionally broad for operator-facing CLI clarity
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
