#!/usr/bin/env bash
set -euo pipefail

: "${CUR_SCRIPT:=$(basename "${BASH_SOURCE[0]:-${0:-}}")}"
export CUR_SCRIPT

: "${PORTMASON_SHARE:="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-${0:-}}")" && pwd -P)"}"
. "${PORTMASON_SHARE}/pm-helpers" "$@"

: "${ENV_FILE:?ENV_FILE is required}"
: "${SITE_DIR:?SITE_DIR is required}"

mkdir -p "$(dirname "${ENV_FILE}.generated")"
mkdir -p "${SITE_DIR}"

"${PORTMASON_SHARE}/pm-util-render-env" \
  --dotenv \
  --out "${ENV_FILE}.generated" \
  "${ENV_FILE}"

"${PORTMASON_SHARE}/pm-util-render-env" \
  --json \
  --out "${SITE_DIR}/config.generated.json" \
  "${ENV_FILE}"