#!/usr/bin/env python3
"""Materialize The Transformation Thread collection selection."""
from __future__ import annotations

import argparse
import hashlib
import html
import json
import os
import re
import tempfile
from dataclasses import dataclass
from datetime import date, datetime
from pathlib import Path
from urllib.parse import quote
from zoneinfo import ZoneInfo

ROOT = Path(__file__).resolve().parents[1]
DEFAULT_COLLECTION = ROOT / "www" / "collections" / "transformation-thread" / "collection.json"
MD_FIELDS = ("title_md", "excerpt_md", "full_article_md")
INLINE_TOKEN = re.compile(r"(`[^`]+`|\*\*[^*]+\*\*|\*[^*]+\*|\[[^\]]+\]\([^)]+\))")


@dataclass(frozen=True)
class Selection:
    selection_date: date
    timezone: str
    active_slot: int
    week_of_month: int
    items: list[dict[str, object]]
    source_sha256: str


def week_of_month(selection_date: date) -> int:
    return ((selection_date.day - 1) // 7) + 1


def slot_cycle(active_slot: int) -> list[int]:
    return [((active_slot - 1 + offset) % 7) + 1 for offset in range(7)]


def collection_context(collection_path: Path) -> tuple[dict[str, object], Path, list[dict[str, object]], bytes, bytes]:
    manifest_raw = collection_path.read_bytes()
    manifest = json.loads(manifest_raw.decode("utf-8"))
    if manifest.get("id") != "transformation-thread" or manifest.get("mode") != "publication":
        raise ValueError("The supplied manifest is not the Transformation Thread publication collection")
    data_file = manifest.get("dataFile")
    if not isinstance(data_file, str) or not data_file:
        raise ValueError("Collection dataFile is required")
    items_path = (collection_path.parent / data_file).resolve()
    if collection_path.parent.resolve() not in items_path.parents:
        raise ValueError("Collection dataFile escapes the collection directory")
    items_raw = items_path.read_bytes()
    items = json.loads(items_raw.decode("utf-8"))
    if not isinstance(items, list):
        raise ValueError("Collection items must be a JSON array")
    return manifest, items_path, items, manifest_raw, items_raw


def resolve_markdown_path(collection_path: Path, ref: object) -> Path:
    if not isinstance(ref, str) or not ref.strip() or not ref.endswith(".md"):
        raise ValueError("Every editorial content reference must be a non-empty .md path")
    collection_dir = collection_path.parent.resolve()
    candidate = (collection_dir / ref).resolve()
    if collection_dir not in candidate.parents:
        raise ValueError(f"Markdown reference escapes its collection: {ref}")
    return candidate


def read_markdown(collection_path: Path, ref: object) -> str:
    path = resolve_markdown_path(collection_path, ref)
    if not path.is_file():
        raise ValueError(f"Markdown file does not exist: {ref}")
    text = path.read_text(encoding="utf-8").strip()
    if not text:
        raise ValueError(f"Markdown file is empty: {ref}")
    return text


def plain_markdown(text: str) -> str:
    value = re.sub(r"`([^`]+)`", r"\1", text)
    value = re.sub(r"\*\*([^*]+)\*\*", r"\1", value)
    value = re.sub(r"\*([^*]+)\*", r"\1", value)
    value = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", value)
    return re.sub(r"\s+", " ", value).strip()


def safe_href(value: str) -> str | None:
    lowered = value.strip().lower()
    return value.strip() if lowered.startswith(("https://", "http://", "mailto:")) else None


def render_inline_markdown(text: str) -> str:
    value = " ".join(text.strip().splitlines())
    output: list[str] = []
    cursor = 0
    for match in INLINE_TOKEN.finditer(value):
        output.append(html.escape(value[cursor:match.start()]))
        token = match.group(0)
        if token.startswith("`"):
            output.append(f"<code>{html.escape(token[1:-1])}</code>")
        elif token.startswith("**"):
            output.append(f"<strong>{html.escape(token[2:-2])}</strong>")
        elif token.startswith("*"):
            output.append(f"<em>{html.escape(token[1:-1])}</em>")
        else:
            link_match = re.fullmatch(r"\[([^\]]+)\]\(([^)]+)\)", token)
            if not link_match:
                output.append(html.escape(token))
            else:
                label, href = link_match.groups()
                safe = safe_href(href)
                output.append(
                    f'<a href="{html.escape(safe, quote=True)}">{html.escape(label)}</a>'
                    if safe else html.escape(label)
                )
        cursor = match.end()
    output.append(html.escape(value[cursor:]))
    return "".join(output)


def source_sha256(manifest_raw: bytes, items_raw: bytes, collection_path: Path, items: list[dict[str, object]]) -> str:
    digest = hashlib.sha256(manifest_raw + items_raw)
    for item in items:
        for field in MD_FIELDS:
            digest.update(resolve_markdown_path(collection_path, item[field]).read_bytes())
    return digest.hexdigest()


def request_url(item_id: int, title_text: str) -> str:
    subject = f"Transformation Thread article request [TT-{item_id:03d}]"
    body = f"Please send Transformation Thread article TT-{item_id:03d}: {title_text}"
    return "mailto:info@etalsolutions.tech?subject=" + quote(subject) + "&body=" + quote(body)


def hydrate_item(item: dict[str, object], collection_path: Path) -> dict[str, object]:
    title_md = read_markdown(collection_path, item["title_md"])
    excerpt_md = read_markdown(collection_path, item["excerpt_md"])
    read_markdown(collection_path, item["full_article_md"])
    hydrated = dict(item)
    hydrated.update({
        "title": plain_markdown(title_md),
        "title_html": render_inline_markdown(title_md),
        "excerpt": plain_markdown(excerpt_md),
        "excerpt_html": render_inline_markdown(excerpt_md),
        "url": request_url(int(item["id"]), plain_markdown(title_md)),
    })
    return hydrated


def validate_items(items: object, collection_path: Path) -> list[dict[str, object]]:
    if not isinstance(items, list) or not items:
        raise ValueError("Transformation Thread collection is empty")
    ids: set[int] = set()
    validated: list[dict[str, object]] = []
    for item in items:
        if not isinstance(item, dict):
            raise ValueError("Each Transformation Thread item must be an object")
        item_id = item.get("id")
        slot = item.get("slot")
        if not isinstance(item_id, int) or item_id < 1:
            raise ValueError("Every publication item needs a positive numeric id")
        if item_id in ids:
            raise ValueError("Publication item ids must be unique")
        if not isinstance(slot, int) or not 1 <= slot <= 7:
            raise ValueError("Every publication slot must be between 1 and 7")
        if item.get("slug") != f"tt-{item_id:03d}":
            raise ValueError("Publication item slug must match its permanent id")
        for field in MD_FIELDS:
            read_markdown(collection_path, item.get(field))
        if any(field in item for field in ("body", "summary", "title")):
            raise ValueError("Editorial display content must live in Markdown files")
        ids.add(item_id)
        validated.append(item)
    return validated


def slot_batch(items: list[dict[str, object]], slot: int, month_week: int) -> list[dict[str, object]]:
    matches = [item for item in items if int(item["slot"]) == slot]
    if not matches:
        return []
    batches = [matches[offset:offset + 3] for offset in range(0, len(matches), 3)]
    return batches[(month_week - 1) % len(batches)]


def select_items(
    manifest: dict[str, object],
    items: list[dict[str, object]],
    manifest_raw: bytes,
    items_raw: bytes,
    selection_date: date,
    collection_path: Path = DEFAULT_COLLECTION,
) -> Selection:
    validated = validate_items(items, collection_path)
    selection_cfg = manifest.get("selection")
    if not isinstance(selection_cfg, dict):
        raise ValueError("Publication selection configuration is required")
    timezone = str(selection_cfg.get("timezone") or "America/New_York")
    visible = max(1, min(int(selection_cfg.get("visibleItems", 3)), len(validated)))
    active_slot = selection_date.isoweekday()
    month_week = week_of_month(selection_date)
    selected: list[dict[str, object]] = []
    seen: set[int] = set()
    for slot in slot_cycle(active_slot):
        for item in slot_batch(validated, slot, month_week):
            if int(item["id"]) in seen:
                continue
            selected.append(item)
            seen.add(int(item["id"]))
            if len(selected) == visible:
                return Selection(
                    selection_date,
                    timezone,
                    active_slot,
                    month_week,
                    [hydrate_item(entry, collection_path) for entry in selected],
                    source_sha256(manifest_raw, items_raw, collection_path, validated),
                )
    for item in validated:
        if int(item["id"]) in seen:
            continue
        selected.append(item)
        seen.add(int(item["id"]))
        if len(selected) == visible:
            break
    return Selection(
        selection_date,
        timezone,
        active_slot,
        month_week,
        [hydrate_item(entry, collection_path) for entry in selected],
        source_sha256(manifest_raw, items_raw, collection_path, validated),
    )


def in_midnight_window(now: datetime) -> bool:
    return now.hour == 0 and 0 <= now.minute < 30


def should_run(now: datetime, require_local_midnight_window: bool, force: bool) -> bool:
    return force or not require_local_midnight_window or in_midnight_window(now)


def public_item(item: dict[str, object]) -> dict[str, object]:
    return {key: item.get(key) for key in [
        "id", "slug", "slot", "category", "status", "title_md", "excerpt_md", "full_article_md",
        "title", "title_html", "excerpt", "excerpt_html", "url",
    ]}


def atomic_write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=path.name + ".", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
        os.replace(tmp_name, path)
    finally:
        if os.path.exists(tmp_name):
            os.unlink(tmp_name)


def materialize(collection_path: Path, selection_path: Path | None, selected_date: date) -> Path:
    manifest, _items_path, items, manifest_raw, items_raw = collection_context(collection_path)
    selection_cfg = manifest.get("selection")
    if not isinstance(selection_cfg, dict):
        raise ValueError("Publication selection configuration is required")
    output_path = selection_path or (collection_path.parent / str(selection_cfg.get("outputFile") or "generated/selection.json"))
    selection = select_items(manifest, items, manifest_raw, items_raw, selected_date, collection_path)
    output = {
        "generated_by": "bin/rotate-transformation-thread",
        "collection": str(manifest["id"]),
        "selection_date": selection.selection_date.isoformat(),
        "rotation_timezone": selection.timezone,
        "active_slot": selection.active_slot,
        "week_of_month": selection.week_of_month,
        "source_sha256": selection.source_sha256,
        "visibleItems": [public_item(item) for item in selection.items],
    }
    atomic_write(output_path, json.dumps(output, indent=2, ensure_ascii=False) + "\n")
    return output_path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--collection", type=Path, default=DEFAULT_COLLECTION)
    parser.add_argument("--selection", type=Path)
    parser.add_argument("--date", type=date.fromisoformat)
    parser.add_argument("--require-local-midnight-window", action="store_true")
    parser.add_argument("--force", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    manifest, _items_path, _items, _manifest_raw, _items_raw = collection_context(args.collection)
    selection_cfg = manifest.get("selection")
    if not isinstance(selection_cfg, dict):
        raise ValueError("Publication selection configuration is required")
    timezone = str(selection_cfg.get("timezone") or "America/New_York")
    now = datetime.now(ZoneInfo(timezone))
    if not should_run(now, args.require_local_midnight_window, args.force):
        print(f"Outside local midnight rotation window: {now.isoformat()}")
        return 0
    selected_date = args.date or now.date()
    output_path = materialize(args.collection, args.selection, selected_date)
    try:
        label = output_path.relative_to(ROOT)
    except ValueError:
        label = output_path
    print(f"Updated {label} for {selected_date.isoformat()}")
    print("Run pm-setup to render the collection into the static site.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
