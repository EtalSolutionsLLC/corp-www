#!/usr/bin/env bash
set -euo pipefail

TARGET_REPO_PATH="${TARGET_REPO_PATH:-deploy/prd/www/index.html}"
TARGET_WORK_PATH="${TARGET_WORK_PATH:-www/index.html}"
EXPECTED_ROTATION_COUNT="${EXPECTED_ROTATION_COUNT:-3}"

old_html="$(mktemp)"
trap 'rm -f "$old_html"' EXIT

if ! git show "HEAD:${TARGET_REPO_PATH}" > "$old_html" 2>/dev/null; then
  echo "BLOG_ROTATION skipped reason=no_prior_file path=${TARGET_REPO_PATH}"
  exit 0
fi

if [[ ! -f "$TARGET_WORK_PATH" ]]; then
  echo "BLOG_ROTATION skipped reason=no_generated_file path=${TARGET_WORK_PATH}"
  exit 0
fi

python3 - "$old_html" "$TARGET_WORK_PATH" "$EXPECTED_ROTATION_COUNT" <<'PY'
from __future__ import annotations

import html
import re
import sys
from pathlib import Path

old_path, new_path = map(Path, sys.argv[1:3])
expected_count = int(sys.argv[3])


def strip_tags(value: str | None) -> str:
    value = re.sub(r"<[^>]+>", "", value or "")
    value = html.unescape(value)
    return " ".join(value.split())


def extract_collection_block(text: str) -> str:
    match = re.search(
        r"<!--\s*PM:COLLECTION-TRANSFORMATION-THREAD\s*-->(.*?)"
        r"<!--\s*/PM:COLLECTION-TRANSFORMATION-THREAD\s*-->",
        text,
        re.IGNORECASE | re.DOTALL,
    )
    return match.group(1) if match else text


def attribute(attrs: str, name: str) -> str:
    match = re.search(
        rf'''\b{re.escape(name)}=["']([^"']+)["']''',
        attrs,
        re.IGNORECASE,
    )
    return html.unescape(match.group(1).strip()) if match else ""


def extract_entries(path: Path) -> list[dict[str, str]]:
    block = extract_collection_block(path.read_text(encoding="utf-8", errors="ignore"))
    article_pattern = re.compile(
        r'''<article\b(?P<attrs>[^>]*\bdata-collection-item-id=["'](?P<id>[^"']+)["'][^>]*)>'''
        r'''(?P<body>.*?)</article>''',
        re.IGNORECASE | re.DOTALL,
    )
    entries: list[dict[str, str]] = []

    for match in article_pattern.finditer(block):
        attrs = match.group("attrs")
        body = match.group("body")
        item_id = match.group("id").strip()
        slot = attribute(attrs, "data-collection-slot")
        category = attribute(attrs, "data-post-category")

        meta_match = re.search(
            r'''<div\b[^>]*class=["'][^"']*\bthread-post-meta\b[^"']*["'][^>]*>(.*?)</div>''',
            body,
            re.IGNORECASE | re.DOTALL,
        )
        meta_values = (
            [strip_tags(value) for value in re.findall(r"<span\b[^>]*>(.*?)</span>", meta_match.group(1), re.IGNORECASE | re.DOTALL)]
            if meta_match
            else []
        )
        if not category and meta_values:
            category = meta_values[1] if meta_values[0].casefold() == "featured" and len(meta_values) > 1 else meta_values[0]

        h3_match = re.search(r"<h3\b[^>]*>(.*?)</h3>", body, re.IGNORECASE | re.DOTALL)
        summary_match = re.search(r"<p\b[^>]*>(.*?)</p>", body, re.IGNORECASE | re.DOTALL)
        title = strip_tags(h3_match.group(1)) if h3_match else f"TT-{item_id}"
        summary = strip_tags(summary_match.group(1)) if summary_match else ""
        tt_id = f"TT-{int(item_id):03d}" if item_id.isdigit() else item_id

        entries.append(
            {
                "id": item_id,
                "tt_id": tt_id,
                "slot": slot,
                "category": category,
                "title": title,
                "summary": summary,
            }
        )

    deduped: list[dict[str, str]] = []
    seen: set[str] = set()
    for entry in entries:
        if entry["id"] in seen:
            continue
        seen.add(entry["id"])
        deduped.append(entry)
    return deduped


def print_entry(prefix: str, entry: dict[str, str]) -> None:
    fields = [
        f'id={entry["id"]}',
        f'tt_id={entry["tt_id"]}',
        f'slot={html.escape(entry["slot"], quote=True)}',
    ]
    if entry["category"]:
        fields.append(f'category="{html.escape(entry["category"], quote=True)}"')
    fields.append(f'title="{html.escape(entry["title"], quote=True)}"')
    print(f"{prefix} " + " ".join(fields))


old_entries = extract_entries(old_path)
new_entries = extract_entries(new_path)
old_ids = {entry["id"] for entry in old_entries}
new_ids = {entry["id"] for entry in new_entries}
removed = [entry for entry in old_entries if entry["id"] not in new_ids]
added = [entry for entry in new_entries if entry["id"] not in old_ids]

print(
    f"BLOG_ROTATION_SUMMARY old_count={len(old_entries)} "
    f"new_count={len(new_entries)} removed_count={len(removed)} added_count={len(added)}"
)
for entry in removed[:expected_count]:
    print_entry("BLOG_REMOVED", entry)
for entry in added[:expected_count]:
    print_entry("BLOG_ADDED", entry)

if not removed and not added and new_entries:
    print("BLOG_ROTATION_STATUS unchanged=true reason=already_current_or_same_rotation")
    for entry in new_entries:
        print_entry("BLOG_CURRENT", entry)

if len(removed) != expected_count or len(added) != expected_count:
    print(
        f"BLOG_ROTATION_NOTICE expected_removed={expected_count} actual_removed={len(removed)} "
        f"expected_added={expected_count} actual_added={len(added)}"
    )
PY
