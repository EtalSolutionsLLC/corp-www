APP_SLUG=etal-misc
DEPLOY_ENV=dev
RUNTIME_ADAPTER_CODE=bash-local

# Optional canonical database selector. Uncomment only when the project uses a
# database. Examples: postgres-local, postgres-neon, postgres-gcp,
# mssql-azure, mssql-azurevm, mssql-azuremanaged.
# DB_PROVIDER_PLATFORM_CODE=postgres-local
# DB_NAME=app
# DB_USER=app_user
# DB_PASSWORD=replace-with-development-only-password
# DB_HOST=
# DB_PORT=5432
# DATABASE_SSL_MODE=disable

# Neon settings for postgres-neon. NEON_API_KEY is a control-plane secret and
# is synchronized to GCP Secret Manager for non-dev GCP deployments.
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_PROJECT_NAME=
# NEON_ORG_ID=
# NEON_BRANCH_NAME=main
# NEON_REGION_ID=aws-us-west-2
# NEON_PG_VERSION=17
# NEON_USE_POOLER=true

# ------------------------------
# anything below this line probably shouldn't be edited manually
# ------------------------------
STACK=${APP_SLUG}-${DEPLOY_ENV}
LOCAL_DOMAIN=localtest.me
APP_HOST=$STACK.$LOCAL_DOMAIN

URI_SCHEME=http:
WP_SITE_URL=$URI_SCHEME//$APP_HOST

# ------------------------------
# Et al Solutions - EPC Tag Contract
# ------------------------------
OWNER_ALIAS=etalsolutions
MANAGED_BY=compose
LIFECYCLE=long-lived
DATA_CLASS=confidential
DATA_LIFECYCLE=persistent
PROJECT_ID=etal-misc-dev-1778610786
DEPLOYMENT_ID=etal-misc-dev-1778610786
