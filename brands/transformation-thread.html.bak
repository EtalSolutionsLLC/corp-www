      <section class="section-light panel" id="overview">
        <div class="container">
          <div class="section-head-center">
            <span class="section-kicker light">Brand Focus</span>
            <h2>What <img class="section-inline-logo" src="https://public.etal.solutions/assets/the-transformation-thread/logos/the-transformation-thread-OFFICIAL.png" alt="The Transformation Thread logo" /> Is Built For</h2>
