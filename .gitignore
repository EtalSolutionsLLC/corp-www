# Portmason-managed local workspace material.
/portmason/
/capture/
/archive/
/logs/
/www/logs/
/.artifacts/

# Downloaded build packages and Windows attachment metadata.
/*.tar.gz
/*-chg.txt
*:Zone.Identifier

# Local recovery and interpreter residue.
/.env.restore
*.bak
*.pyc
__pycache__/

# Runtime-generated build metadata is deployed with the Pages artifact but is
# not committed because its timestamp changes on every materialization.
/www/build-info.json
/www/deploy-info.json
/www/artifact-manifest.json
/deploy/*/www/build-info.json
/deploy/*/www/deploy-info.json
/deploy/*/www/artifact-manifest.json
/.portmason-version.lock

# Keep the generated Portmason contract files tracked.
!.env.generated
!config.generated.json

# Track authoritative project automation despite workstation-wide bin/ rules.
!/bin/
/bin/*
!/bin/cleanup-root
!/bin/report-blog-rotation
!/bin/rotate-transformation-thread

# Each deploy directory is a complete deployment snapshot. Preserve its bin/
# contents even when a workstation-wide Git ignore file excludes bin folders.
!/deploy/*/bin/
!/deploy/*/bin/**
