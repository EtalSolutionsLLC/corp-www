# Portmason-managed local workspace material.
/portmason/
/capture/
/archive/
/logs/
/www/logs/
/.artifacts/

# Downloaded build packages and Windows attachment metadata.
/*.tar.gz
/*-chg.txt
*:Zone.Identifier

# Local recovery and interpreter residue.
/.env.restore
*.bak
*.pyc
__pycache__/

# Keep the generated Portmason contract files tracked.
!.env.generated
!config.generated.json

# Track the production rotation report while keeping other staged bin files local.
!/deploy/prd/bin/
/deploy/prd/bin/*
!/deploy/prd/bin/report-blog-rotation
