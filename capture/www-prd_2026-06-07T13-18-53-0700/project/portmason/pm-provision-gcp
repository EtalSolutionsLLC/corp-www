bind_service_account(){
    local sa_email="${1:?sa email required}"

    local role

    # storage bucket
    if [[ -n "${GCS_BUCKET:-}" ]]; then
        log "Ensure GCS_BUCKET access for '${sa_email}'"
        role="storage.objectAdmin"
        local resource=="//storage.googleapis.com/projects/_/buckets/${GCS_BUCKET}"
        if ! iam_cache_has_binding "${resource}" "${sa_email}" "${role}"; then
            gcloud storage buckets add-iam-policy-binding "gs://${GCS_BUCKET}" \
                --member="serviceAccount:${sa_email}" \
                --role="roles/${role}" >/dev/null || true
            iam_cache_add_binding "${resource}" "${sa_email}" "${role}"
        fi
    fi

    # secrets
    log "Ensure secret access for '${sa_email}'"
    role="secretmanager.secretAccessor"
    while IFS= read -r secret_name; do
        local resource="//secretmanager.googleapis.com/projects/${DEPLOYMENT_ID}/secrets/${secret_name}"
        if ! iam_cache_has_binding "${resource}" "${sa_email}" "${role}"; then
            gcloud secrets add-iam-policy-binding "$secret_name" \
                --member="serviceAccount:${sa_email}" \
                --role="roles/secretmanager.secretAccessor" >/dev/null || true
            iam_cache_add_binding "${resource}" "${sa_email}" "${role}"
        fi
    done < <(get_secret_names_list)
}

ensure_apis() {
    log "Verify/Enable required APIs"

    if [[ -z "${GCLOUD_ENABLED_SERVICE_NAMES:-}" ]]; then
        if ! GCLOUD_ENABLED_SERVICE_NAMES="$(gcloud services list --enabled --project "${DEPLOYMENT_ID}" --format='value(config.name)')"; then
            GCLOUD_ENABLED_SERVICE_NAMES=""
        fi
        export GCLOUD_ENABLED_SERVICE_NAMES
        log "GCLOUD_ENABLED_SERVICE_NAMES=${GCLOUD_ENABLED_SERVICE_NAMES}"
    fi

    for api in \
        run.googleapis.com \
        cloudbuild.googleapis.com \
        artifactregistry.googleapis.com \
        sqladmin.googleapis.com \
        secretmanager.googleapis.com \
        iamcredentials.googleapis.com \
        cloudresourcemanager.googleapis.com
    do
        if ! printf '%s\n' "$GCLOUD_ENABLED_SERVICE_NAMES" | grep -Fxq "$api"; then
            log "Enabling API: $api"
            if gcloud services enable "$api" --project "$DEPLOYMENT_ID" >/dev/null 2>&1; then
                if [[ -z "${GCLOUD_ENABLED_SERVICE_NAMES:-}" ]]; then
                    GCLOUD_ENABLED_SERVICE_NAMES="$api"
                else
                    GCLOUD_ENABLED_SERVICE_NAMES+=$'\n'"$api"
                fi
            fi
        else
            log "API already enabled: $api"
        fi
    done
}

ensure_repo() {
    if [[ -z "${AR_REPO:-}" ]]; then
        log "AR_REPO is undefined; skipping repo creation"
        return 0
    fi

    # 6) Ensure AR repo (with short retry for propagation)
    log "Ensure repo '${AR_REPO}' in ${REGION}"
    for i in {1..3}; do
        if gcloud artifacts repositories describe "${AR_REPO}" --location "${REGION}" >/dev/null 2>&1; then break; fi
        if gcloud artifacts repositories create "${AR_REPO}" --repository-format=docker --location="${REGION}" --description="Containers for ${APP_SLUG}" >/dev/null 2>&1; then break; fi
        log "Repo creation attempt $i failed; waiting 10s…"; sleep 10
    done

    return 0
}


ensure_bucket() {
  if [[ -z "${GCS_BUCKET:-}" ]]; then
     log "GCS_BUCKET is undefined; skipping bucket creation"
    return 0
  fi

  if gcloud storage buckets describe "gs://${GCS_BUCKET}" >/dev/null 2>&1; then
    log "Bucket exists: gs://${GCS_BUCKET}"
    return 0
  fi

  log "Creating bucket: gs://${GCS_BUCKET} (region=${REGION})"
  gcloud storage buckets create "gs://${GCS_BUCKET}" --location="$REGION" >/dev/null

  return 0
}

ensure_env_tag() {
    local base_project_id=github-archive-480721
    local base_parent="projects/$base_project_id"
    local keyname='environment'
    local keyvalue="$(get_cm_env_value "$CM_ENV" long)" || die "get_cm_env_value failed with '$CM_ENV'"
    keyvalue="${keyvalue^}"

    local target_project_number="$(jq -er '.projectNumber' <<<"$GCLOUD_PROJECT_INFO_JSON")"
    local target_parent="//cloudresourcemanager.googleapis.com/projects/$target_project_number"

    log "Ensuring project has an '$keyname' tag"

    # ---- Find Tag Key NAME (tagKeys/<id>) scoped to base project ----
    # IMPORTANT: Use the base project scope to avoid collisions.
    local tag_key_name="$(
    gcloud resource-manager tags keys list \
        --parent="$base_parent" \
        --filter="shortName=$keyname" \
        --format='value(name)' \
        --limit=1
    )"

    [[ -n "$tag_key_name" ]] || { error "Tag Key '${keyname}' not found under ${base_parent}"; return 1; }
    [[ "$(printf '%s\n' "$tag_key_name" | grep -c .)" -le 1 ]] || { error "Multiple Tag Keys matched '${keyname}' under ${base_parent}"; return 2; }

    # ---- Find Tag Value NAME (tagValues/<id>) under the key ----
    local tag_value_name="$(
    gcloud resource-manager tags values list     \
        --parent="$tag_key_name" \
        --filter="shortName=$keyvalue" \
        --format='value(name)' \
        --limit=1
    )"

    if [[ -z "$tag_value_name" ]]; then
        tag_value_name="$(
            gcloud resource-manager tags values create "${keyvalue}" \
                --parent="${tag_key_name}" \
                --format="value(name)"
        )" || { error "Failed to create tag value ${keyvalue}"; return 3; }
    fi

    [[ -n "$tag_value_name" ]] || { error "Tag Value '${keyvalue}' not found under Tag Key '${keyname}'"; return 3; }
    [[ "$(printf '%s\n' "$tag_value_name" | grep -c .)" -le 1 ]] || { error "Multiple Tag Values matched '${keyvalue}' under ${tag_key_name}"; return 4; }

    # Bindings list returns tagValue (tagValues/...). To figure out if that value belongs to TAG_KEY_NAME,
    # we have to look up each value's parent (which is tagKeys/<id>).

    local existing_tag_values="$(
        gcloud resource-manager tags bindings list \
        --parent="$target_parent" \
        --format='value(tagValue)' 2>/dev/null || true
    )"

    if printf '%s\n' "$existing_tag_values" | grep -Fxq "$tag_value_name"; then
        log "Tag already bound: $tag_value_name"
        return 0
    fi

    local existing_parent_key
    if [[ -n "$existing_tag_values" ]]; then
        while IFS= read -r existing_tv; do
            [[ -z "$existing_tv" ]] && continue

            # Determine which key this tag value belongs to
            existing_parent_key="$(
                gcloud resource-manager tags values describe "$existing_tv" --format='value(parent)' 2>/dev/null || true
            )"

            if [[ "$existing_parent_key" = "$tag_key_name" && "$existing_tv" != "$tag_value_name" ]]; then
                log "Unbinding old value for key '$keyname': $existing_tv"
                # Delete needs both parent + tag-value
                gcloud resource-manager tags bindings delete \
                --parent="$target_parent" \
                --tag-value="$existing_tv" >/dev/null
            fi
        done <<< "$existing_tag_values"
    fi

    # ---- Create binding (treat ALREADY_EXISTS as success) ----
    set +e
    local out="$(gcloud resource-manager tags bindings create \
        --tag-value="$tag_value_name" \
        --parent="$target_parent" 2>&1
    )"
    local rc=$?
    set -e

    if [[ $rc -eq 0 ]] || printf '%s' "$out" | grep -qiE 'ALREADY_EXISTS|already exists'; then
      log "Tag ensured: ${keyname}=${keyvalue}"
      return 0
    fi

    error "failed to create tag binding (rc=$rc): $out" >&2
    return "$rc"
}

ensure_project(){
    # 1) Create or check project + billing
    log "Checking if project '${DEPLOYMENT_ID}' already exists"

    GCLOUD_PROJECT_INFO_JSON="$(gcloud projects describe "${DEPLOYMENT_ID}" --format=json 2>/dev/null || echo '{}')"
    export GCLOUD_PROJECT_INFO_JSON
    log "GCLOUD_PROJECT_INFO_JSON=${GCLOUD_PROJECT_INFO_JSON}"

    if [[ -n "${GCLOUD_PROJECT_INFO_JSON:-}" && "${GCLOUD_PROJECT_INFO_JSON}" != "{}" ]]; then
        local state="$(jq -er '.lifecycleState' <<<"$GCLOUD_PROJECT_INFO_JSON")"
        if [[ "$state" == "DELETE_REQUESTED" ]]; then
            die "project ${DEPLOYMENT_ID} is in DELETE_REQUESTED. Wait for deletion to finish or choose a new ID." 3
        fi

        GCLOUD_BILLING_JSON="$(gcloud billing projects describe "${DEPLOYMENT_ID}" --format=json 2>/dev/null || echo '{}')"
        export GCLOUD_BILLING_JSON
        local billing_enabled="$(jq -r '.billingEnabled // false' <<<"$GCLOUD_BILLING_JSON")"

        if [[ "$billing_enabled" != "true" ]]; then
            log "linking to ${BILLING_ACCOUNT}"
            gcloud billing projects link "${DEPLOYMENT_ID}" --billing-account "${BILLING_ACCOUNT}"
        else
            log "Project '${DEPLOYMENT_ID}' already exists and is linked to billing account '${BILLING_ACCOUNT}'"
        fi
    else
        log "creating ${DEPLOYMENT_ID}"
        gcloud projects create "${DEPLOYMENT_ID}" --name="${STACK}"
        log "linking to ${BILLING_ACCOUNT}"
        gcloud billing projects link "${DEPLOYMENT_ID}" --billing-account "${BILLING_ACCOUNT}"

        GCLOUD_PROJECT_INFO_JSON="$(gcloud projects describe "${DEPLOYMENT_ID}" --format=json)"
        export GCLOUD_PROJECT_INFO_JSON
        log "GCLOUD_PROJECT_INFO_JSON=${GCLOUD_PROJECT_INFO_JSON}"

        GCLOUD_BILLING_JSON="$(gcloud billing projects describe "${DEPLOYMENT_ID}" --format=json)"
        export GCLOUD_BILLING_JSON
#    else
#        die "unknown (auth/perm/config issue)" 2
    fi
    log "GCLOUD_BILLING_JSON=${GCLOUD_BILLING_JSON}"

    if [[ -z "${GCLOUD_POLICY_JSON:-}" ]]; then
        GCLOUD_POLICY_JSON="$(gcloud projects get-iam-policy "${DEPLOYMENT_ID}" --format=json 2>/dev/null || echo '{}')"
        export GCLOUD_POLICY_JSON
    fi
    log "GCLOUD_POLICY_JSON=${GCLOUD_POLICY_JSON}"

    ensure_env_tag

    if [[ -z "${GCLOUD_CONFIG_JSON:-}" ]]; then
        GCLOUD_CONFIG_JSON="$(gcloud config list --format=json 2>/dev/null || echo '{}')"
        export GCLOUD_CONFIG_JSON
    fi
    log "GCLOUD_CONFIG_JSON=${GCLOUD_CONFIG_JSON}"

    # 2) Verify/Set ADC quota project EARLY (silences warnings)
    log "Verify/Set ADC quota project → ${DEPLOYMENT_ID}"
    local adc_file="${XDG_CONFIG_HOME:-$HOME/.config}/gcloud/application_default_credentials.json"
    local adc_quota_project="$(jq -r '.quota_project_id // empty' "$adc_file" 2>/dev/null || true)"
    if [[ "${adc_quota_project:-}" != "$DEPLOYMENT_ID" ]]; then
        gcloud auth application-default set-quota-project "$DEPLOYMENT_ID" >/dev/null
        # Patch cached value (no extra file read)
        adc_quota_project="$DEPLOYMENT_ID"
    fi

    local adc_quota_project="$(jq -r '.quota_project_id // empty' "$adc_file" 2>/dev/null || true)"
    [[ "$(grep -o '"quota_project_id":[^,]*' "${XDG_CONFIG_HOME:-$HOME/.config}/gcloud/application_default_credentials.json" 2>/dev/null | awk -F\" '{print $4}' || true)" != "$DEPLOYMENT_ID" ]] \
        && gcloud auth application-default set-quota-project "$DEPLOYMENT_ID" >/dev/null

    # 3) gcloud defaults (GCLOUD_CONFIG_JSON is a cached `gcloud config list --format=json` result)

    log "Verify/Set project → ${DEPLOYMENT_ID}"
    local cur_project
    cur_project="$(jq -r '.core.project // empty' <<<"$GCLOUD_CONFIG_JSON")"
    if [[ "$cur_project" != "$DEPLOYMENT_ID" ]]; then
        gcloud config set project "$DEPLOYMENT_ID" >/dev/null
        GCLOUD_CONFIG_JSON="$(jq -c --arg v "$DEPLOYMENT_ID" '.core.project = $v' <<<"$GCLOUD_CONFIG_JSON")"
        export GCLOUD_CONFIG_JSON
    fi

    log "Verify/Set region → $REGION"
    local cur_run_region
    cur_run_region="$(jq -r '.run.region // empty' <<<"$GCLOUD_CONFIG_JSON")"
    if [[ "$cur_run_region" != "$REGION" ]]; then
        gcloud config set run/region "$REGION" >/dev/null
        GCLOUD_CONFIG_JSON="$(jq -c --arg v "$REGION" '.run.region = $v' <<<"$GCLOUD_CONFIG_JSON")"
        export GCLOUD_CONFIG_JSON
    fi

    log "Verify/Set artifacts.location → $REGION"
    local cur_ar_loc
    cur_ar_loc="$(jq -r '.artifacts.location // empty' <<<"$GCLOUD_CONFIG_JSON")"
    if [[ "$cur_ar_loc" != "$REGION" ]]; then
        gcloud config set artifacts/location "$REGION" >/dev/null
        GCLOUD_CONFIG_JSON="$(jq -c --arg v "$REGION" '.artifacts.location = $v' <<<"$GCLOUD_CONFIG_JSON")"
        export GCLOUD_CONFIG_JSON
    fi

    return 0
}

ensure_project_role() {
    local role="${1:?role required}"
    local member="user:${GCLOUD_ACTIVE_USER:?GCLOUD_ACTIVE_USER required}"

    # Normalize role to avoid INVALID_ARGUMENT from stray whitespace/CR
    role="${role//$'\r'/}"
    role="$(xargs <<<"$role")"

    if [[ ! "$role" =~ ^(roles|projects/[a-z0-9-]+/roles|organizations/[0-9]+/roles)/[A-Za-z0-9_.-]+$ ]]; then
        die "Bad role string (expected roles/foo or projects/*/roles/foo or organizations/*/roles/foo): '$role'"
    fi

    # Fetch IAM policy once for performance (JSON, stable for parsing)
    if [[ -z "${GCLOUD_POLICY_JSON:-}" ]]; then
        if ! GCLOUD_POLICY_JSON="$(gcloud projects get-iam-policy "${DEPLOYMENT_ID}" --format=json 2>/dev/null)"; then
            GCLOUD_POLICY_JSON='{}'
        fi
        export GCLOUD_POLICY_JSON
        log "GCLOUD_POLICY_JSON loaded"
    fi

    # Exact membership check
    if jq -e --arg r "$role" --arg m "$member" \
        'any(.bindings[]?; .role == $r and any(.members[]?; . == $m))' \
        >/dev/null 2>&1 <<<"$GCLOUD_POLICY_JSON"; then
        log "  = already has ${role}"
        return 0
    fi

    # Fast path: try add-iam-policy-binding
    if gcloud projects add-iam-policy-binding "${DEPLOYMENT_ID}" \
        --member="$member" \
        --role="$role" >/dev/null 2>&1; then
        log "  + granted ${role} (add-iam-policy-binding)"
    else
        # Slow-but-reliable path for conditional policies:
        # Update cached policy JSON and set it back.
        log "  ! add-iam-policy-binding failed; applying via set-iam-policy"

        GCLOUD_POLICY_JSON="$(
        jq -c --arg r "$role" --arg m "$member" '
            .bindings = (.bindings // [])
            | (if any(.bindings[]?; .role == $r) then .
            else .bindings += [{role:$r, members:[]}] | .
            end)
            | .bindings = (
                .bindings
                | map(
                    if .role != $r then .
                    else .members = ((.members // []) | (if index($m) then . else . + [$m] end))
                    end
                )
            )
        ' <<<"$GCLOUD_POLICY_JSON" 2>/dev/null || printf '%s' '{}'
        )"

        local tmp_policy
        tmp_policy="$(mktemp)"
        printf '%s\n' "$GCLOUD_POLICY_JSON" >"$tmp_policy"

        gcloud projects set-iam-policy "${DEPLOYMENT_ID}" "$tmp_policy" >/dev/null \
        || { rm -f "$tmp_policy"; die "Failed to set IAM policy for ${DEPLOYMENT_ID}"; }

        rm -f "$tmp_policy"
        export GCLOUD_POLICY_JSON
        log "  + granted ${role} (set-iam-policy)"
    fi

    # Keep cache accurate for the rest of this run (manual patch is harmless even on fast path)
    GCLOUD_POLICY_JSON="$(
        jq -c --arg r "$role" --arg m "$member" '
        .bindings = (.bindings // [])
        | (if any(.bindings[]?; .role == $r) then .
            else .bindings += [{role:$r, members:[]}] | .
            end)
        | .bindings = (
            .bindings
            | map(
                if .role != $r then .
                else .members = ((.members // []) | (if index($m) then . else . + [$m] end))
                end
                )
            )
        ' <<<"$GCLOUD_POLICY_JSON" 2>/dev/null || printf '%s' '{}'
    )"
    export GCLOUD_POLICY_JSON

    return 0
}

ensure_project_roles() {
    log "Ensuring roles for user:${GCLOUD_ACTIVE_USER}"

    ensure_project_role "roles/artifactregistry.admin"
    ensure_project_role "roles/admin"
    [[ -n "${CLOUD_SQL_INSTANCE:-}" ]] && ensure_project_role "roles/cloudsql.admin"

    return 0
}

ensure_scheduler() {
  if [[ -z "${SCHED_NAME:-}" ]]; then
     log "SCHED_NAME is undefined; skipping Cloud Scheduler creation"
    return 0
  fi

  local run_url="https://run.googleapis.com/v2/projects/${DEPLOYMENT_ID}/locations/${REGION}/jobs/${RUN_JOB}:run"
  local body='{}'

  log "Ensuring Cloud Scheduler job exists: ${SCHED_NAME}"
  if gcloud scheduler jobs describe "$SCHED_NAME" --location "$REGION" >/dev/null 2>&1; then
    log "Updating Cloud Scheduler job: ${SCHED_NAME}"
    gcloud scheduler jobs update http "$SCHED_NAME" \
      --location "$REGION" \
      --schedule "$SCHEDULE_CRON" \
      --time-zone "$SCHED_TIMEZONE" \
      --uri "$run_url" \
      --http-method POST \
      --update-headers "Content-Type=application/json" \
      --message-body "$body" \
      --oauth-service-account-email "$SCHED_SA" \
      >/dev/null
  else
    log "Creating Cloud Scheduler job: ${SCHED_NAME}"
    gcloud scheduler jobs create http "$SCHED_NAME" \
      --location "$REGION" \
      --schedule "$SCHEDULE_CRON" \
      --time-zone "$SCHED_TIMEZONE" \
      --uri "$run_url" \
      --http-method POST \
      --headers "Content-Type=application/json" \
      --message-body "$body" \
      --oauth-service-account-email "$SCHED_SA" \
      >/dev/null
  fi

    return 0
}

ensure_service_accounts() {
    local compose_file="${1:-docker-compose.yml}"
    log "Resolving service names from ${compose_file}..."

    if [[ -z "${PROJECT_SERVICES:-}" ]]; then
        export PROJECT_SERVICES="$(
            pm-util-render-env "${compose_file}" \
            | yq -o=json '
                (.services // {})
                | to_entries
                | map(select(.value.image))
                | map({"service": .key, "image": .value.image})
                ' -
            )"
    fi

    if [[ -z "${GCLOUD_SERVICE_ACCOUNT_EMAILS:-}" ]]; then
        if ! GCLOUD_SERVICE_ACCOUNT_EMAILS="$(gcloud iam service-accounts list --project "$DEPLOYMENT_ID" --format="value(email)")"; then
            GCLOUD_SERVICE_ACCOUNT_EMAILS=""
        fi
        export GCLOUD_SERVICE_ACCOUNT_EMAILS
        log "GCLOUD_SERVICE_ACCOUNT_EMAILS=${GCLOUD_SERVICE_ACCOUNT_EMAILS}"
    fi

    while IFS=$'\t' read -r svc img; do
        [[ "${svc}" == "db" ]] || { ensure_service_account "$(format_sa_email "${svc}")"; }
    done < <(echo "$PROJECT_SERVICES" | jq -r '.[] | "\(.service)\t\(.image)"')
}

ensure_service_account() {
    local sa_email="$1"
    local sa_name="${2:-"${sa_email%@*}"}"
    local sa_desc="${3:-"Service account for ${sa_name}"}"

    if grep -Fxq "$sa_email" <<< "${GCLOUD_SERVICE_ACCOUNT_EMAILS:-}"; then
        log "Service account exists: ${sa_email}"
        return 0
    fi

    log "Creating service account: ${sa_email}"
    gcloud iam service-accounts create "$sa_name" --description="$sa_desc" >/dev/null
    GCLOUD_SERVICE_ACCOUNT_EMAILS="${GCLOUD_SERVICE_ACCOUNT_EMAILS}"$'\n'"$sa_email"

    return 0
}

ensure_sql() {
    if [[ -z "${CLOUD_SQL_INSTANCE:-}" ]]; then
        log "CLOUD_SQL_INSTANCE is undefined; skipping cloud sql creation"
        return 0
    fi

    local stack
    if [[ -n "${DB_NAME:-}" ]]; then
        . "${PORTMASON_SHARE}/pm-ensure-sqlinstance-gcp"

        if [[ "${CLOUD_SQL_INSTANCE_CREATED_ANEW:-0}" == 1 ]]; then
            log ""
            log "Updating password for root user..."
            gcloud sql users set-password root \
                --instance='${CLOUD_SQL_INSTANCE}' \
                --host="${DB_HOST}" \
                --password="${DB_ROOT_USER}" \
                --quiet
        fi

        if [[ -n "${DB_NAME:-}" ]]; then
            log "Checking if database '${DB_NAME}' already exists..."
            if ! gcloud sql databases describe ${DB_NAME} --instance=${CLOUD_SQL_INSTANCE} >/dev/null 2>&1; then
                log "Creating database '${DB_NAME}' on instance '${CLOUD_SQL_INSTANCE}'..."
                gcloud sql databases create ${DB_NAME} \
                    --instance="${CLOUD_SQL_INSTANCE}" \
                    --charset="${CLOUD_SQL_DB_CHARSET}" \
                    --collation="${CLOUD_SQL_DB_COLLATE}" \
                    --quiet
            fi
        fi

        if [[ -n "${DB_USER:-}" ]]; then
            log "Checking if user '${DB_USER}' already exists..."
            if ! gcloud sql users list --instance="${CLOUD_SQL_INSTANCE}" --format="value(name,host)" | grep -qx "${DB_USER} ${DB_HOST}"; then
                log "Creating user '${DB_USER}' on instance '${CLOUD_SQL_INSTANCE}'..."
                gcloud sql users create ${DB_USER} \
                    --instance="${CLOUD_SQL_INSTANCE}" \
                    --host-"${DB_HOST}" \
                    --quiet
            fi

            log "Updating password for user '${DB_USER}'..."
            gcloud sql users set-password "${DB_USER}" \
                --instance='${CLOUD_SQL_INSTANCE}' \
                --host="${DB_HOST}" \
                --password=NEW_PASSWORD \
                --quiet
        fi
    fi
}

iam_cache_add_binding() {
  local role="${1:?role required}"       # e.g. roles/storage.objectAdmin
  local member="${2:?member required}"   # e.g. user:... serviceAccount:...

  # Ensure cache is at least an object
  if [[ -z "${GCLOUD_POLICY_JSON:-}" ]]; then
    GCLOUD_POLICY_JSON='{}'
  fi

  # Normalize to valid JSON object; if invalid, reset
  if ! jq -e 'type=="object"' >/dev/null 2>&1 <<<"$GCLOUD_POLICY_JSON"; then
    GCLOUD_POLICY_JSON='{}'
  fi

  GCLOUD_POLICY_JSON="$(
    jq -c --arg r "$role" --arg m "$member" '
      .bindings = (.bindings // [])

      # ensure role binding exists
      | (if any(.bindings[]?; .role == $r) then .
         else .bindings += [{role:$r, members:[]}] | .
         end)

      # ensure member exists in that role binding
      | .bindings = (
          .bindings
          | map(
              if .role != $r then .
              else .members = ((.members // []) | (if index($m) then . else . + [$m] end)) | .
              end
            )
        )
    ' <<<"$GCLOUD_POLICY_JSON" 2>/dev/null || printf '%s' '{}'
  )"

  export GCLOUD_POLICY_JSON
}

iam_cache_has_binding() {
  local member="${1:?member required}"   # e.g. user:..., serviceAccount:...
  local role="${2:?role required}"       # e.g. roles/storage.objectAdmin

  jq -e --arg m "$member" --arg r "$role" '
    any(.bindings[]?; .role == $r and any(.members[]?; . == $m))
  ' >/dev/null 2>&1 <<<"${GCLOUD_POLICY_JSON:-{}}"
}

main() {
    have gcloud || die "Missing required command: gcloud"

    export GCLOUD_ACTIVE_USER="$(gcloud auth list --filter=status:ACTIVE --format='value(account)')"

    ensure_project

    ensure_project_roles

    ensure_apis

    ensure_bucket

    ensure_repo

    confirm_and_publish_mgt_scripts_artifact

    ensure_service_accounts

    ensure_sql

    ensure_scheduler

    bind_permissions

    log "Done."
}

main "$@"
