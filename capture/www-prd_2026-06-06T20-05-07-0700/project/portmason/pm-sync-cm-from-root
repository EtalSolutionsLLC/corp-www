#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") [-o|--overwrite]"
  echo
  echo "Sync files from repo root into the current env directory (cm/qas, cm/prd, etc)."
  echo
  echo "Rules:"
  echo "  - Must be run from an env dir whose parent is 'cm'."
  echo "  - Default: if the env dir contains anything except .env or .env.example, NO-OP."
  echo "  - -f/--force overrides and allows overwriting existing files."
  echo
  echo "Exclusions when copying from root:"
  echo "  .env*, .env.example*, logs, capture, cm, .git, .github"
}

. "${PORTMASON_SHARE}/pm-helpers-base"

env_is_clean() {
  shopt -s nullglob dotglob
  local here="$PWD"
  local item name

  for item in "$here"/*; do
    name="$(basename "$item")"

    case "$name" in
      *.env|*.env.example|*.env.bak|logs|.env.generated)
        # allowed
        ;;
      *)
        # something else present → dirty
        return 1
        ;;
    esac
  done

  return 0  # clean
}

cm_sync_from_root() {
  local overwrite="$1"
  local env_dir root_dir item name target

  env_dir="$PWD"

  # ---------------------------------------------------------
  # Verify we are inside an env folder (cm/qas or cm/prd etc)
  # ---------------------------------------------------------
  if ! is_env_dir; then
    echo "ERROR: Must run from an environment folder (parent must be 'cm')."
    return 1
  fi

  # ---------------------------------------------------------
  # Enforce 'clean env' unless force
  # ---------------------------------------------------------
  if ! env_is_clean && [[ "$overwrite" -ne 1 ]]; then
    echo "Environment folder '$env_dir' is already populated with files other than .env and .env.example"
    echo "NO-OP. Use -o/--overwrite to override."
    return 0
  fi

  # ---------------------------------------------------------
  # Detect repo root
  # ---------------------------------------------------------
  if root_dir=$(git rev-parse --show-toplevel 2>/dev/null); then
    true
  else
    root_dir="$(cd "$env_dir/../.." && pwd)"
  fi

  echo "Repo root:   $root_dir"
  echo "Env folder:  $env_dir"
  echo "Mode:        $([[ "$overwrite" -eq 1 ]] && echo "force OVERWRITE" || echo "safe/no-overwrite")"
  echo

  if [[ ! -d "$root_dir" ]]; then
    echo "ERROR: repo root '$root_dir' not found." >&2
    return 1
  fi

  # ---------------------------------------------------------
  # Perform copy
  # ---------------------------------------------------------
  shopt -s dotglob nullglob

  for item in "$root_dir"/*; do
    name="$(basename "$item")"

    case "$name" in
      .env|.env*|*env*|*env|.env.example|.env.example*|*env.example*|*env.example|.env.generated|.env.generated*|*env.generated*|*env.generated)
        echo "Skipping env file: $name"
        continue
        ;;
      logs|capture|cm)
        echo "Skipping excluded dir: $name"
        continue
        ;;
      docker-compose.*.yml)
        echo "Skipping excluded file: $name"
        continue
        ;;
      .project_timestamp)
        echo "Skipping excluded file: $name"
        continue
        ;;
      .htaccess)
        echo "Skipping excluded file: $name"
        continue
        ;;
      .git*)
        echo "Skipping VCS: $name"
        continue
        ;;
    esac

    target="$env_dir/$name"

    if [[ -e "$target" && "$overwrite" -ne 1 ]]; then
      echo "Exists, not overwriting: $name"
      continue
    fi

    if [[ -d "$item" ]]; then
      echo "Copying directory: $name"
      cp -R "$item" "$target"
    else
      echo "Copying file: $name"
      cp "$item" "$target"
    fi
  done

  echo
  echo "Sync complete."

  return 0
}

main() {
  pm_setup_arg OVERWRITE "-o|--overwrite"
  pm_commit_args "$@"

  cm_sync_from_root "$OVERWRITE"

  return 0
}

main "$@"
